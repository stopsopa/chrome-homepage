{
  "manifest_version": 3,
  "name": "Custom New Tab Redirect",
  "version": "1.1",
  "description": "Redirects the new tab to a custom link.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Set New Tab Link"
  },
  "chrome_url_overrides": {
    "newtab": "homepage.html"
  }
}
