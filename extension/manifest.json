{
  "manifest_version": 3,
  "name": "Custom New Tab Mangement v2",
  "version": "0.1",
  "description": "Renders a custom local new tab page.",
  "chrome_url_overrides": {
    "newtab": "homepage.html"
  },
  "permissions": ["bookmarks", "tabs", "scripting"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://t3.chat/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*", "https://chatgpt.com/*", "https://claude.ai/*", "https://t3.chat/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "images/icon128.png"
  }
}
