{
  "manifest_version": 3,
  "name": "Custom New Tab Redirect",
  "version": "1.1",
  "description": "Renders a custom local new tab page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Set New Tab Link"
  },
  "chrome_url_overrides": {
    "newtab": "homepage.html"
  },
  "permissions": ["bookmarks", "tabs", "scripting"],
  "host_permissions": ["https://gemini.google.com/*", "https://chatgpt.com/*", "https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*", "https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "images/icon128.png"
  }
}
